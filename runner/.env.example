# Runner-Secrets (lokal, NICHT committen — runner/.env ist gitignored).
# Kopiere diese Datei zu runner/.env und trage die Werte ein.

# Supabase-Projekt (gleiche URL wie im Frontend, app/.env.local → VITE_SUPABASE_URL)
SUPABASE_URL=https://DEIN-PROJEKT.supabase.co

# service_role-Key: Supabase-Dashboard → Project Settings → API → service_role.
# ACHTUNG: umgeht RLS. Bleibt nur hier lokal auf dem Mac, kommt NIE ins Frontend/Repo.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Push-Intervall in ms (Default 60000 = 60s).
# SNAPSHOT_PUSH_MS=60000
